# YouTube API Key
NEXT_PUBLIC_YOUTUBE_API_KEY=your_youtube_api_key_here

# YouTube Playlist ID for Episodes
NEXT_PUBLIC_YOUTUBE_PLAYLIST_ID=your_youtube_playlist_id_here

# Sanity CMS
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=your_sanity_read_token
SANITY_REVALIDATE_SECRET=your_webhook_secret

# Sanity MCP Server (Agent Toolkit)
# No additional env vars needed — MCP uses OAuth via `npx sanity@latest mcp configure`
# The MCP server at https://mcp.sanity.io connects using your Sanity CLI login

# Note: Variables prefixed with NEXT_PUBLIC_ will be available in the browser
# For server-side only variables, do not use the NEXT_PUBLIC_ prefix 
